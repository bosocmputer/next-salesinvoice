{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Requests/min",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(nsi_http_requests_total[5m])) * 60",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1 } }
    },
    {
      "type": "stat",
      "title": "Error rate (5xx)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(nsi_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(nsi_http_requests_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 } ] } } }
    },
    {
      "type": "stat",
      "title": "p95 latency",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(nsi_http_request_duration_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
    },
    {
      "type": "stat",
      "title": "Login failures/min",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(nsi_login_attempts_total{result!=\"success\"}[5m])) * 60",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 } ] } } }
    },
    {
      "type": "timeseries",
      "title": "Requests by route",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (route) (rate(nsi_http_requests_total[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(nsi_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(nsi_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(nsi_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Login attempts by result",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (result) (rate(nsi_login_attempts_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Bulk apply outcomes (docs/5m)",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (outcome) (increase(nsi_bulk_apply_documents_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Client events (errors / rejections / vitals)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(nsi_client_events_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",

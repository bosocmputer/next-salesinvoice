# next-salesinvoice environment variables
# Copy to .env and fill in values before deploying

# Session secret — must be at least 32 characters, unique per deployment
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Setup secret used for database-bootstrap endpoint (optional, leave empty to disable)
NSI_DATABASE_SETUP_SECRET=

# SML PostgreSQL connection
SML_DB_HOST=192.168.2.248
SML_DB_PORT=5432
SML_DB_NAME=sml1_2026
SML_DB_USER=postgres
SML_DB_PASSWORD=
SML_DB_SSLMODE=disable
SML_DB_SCHEMA=public

# Conservative connection pool (default 3 is fine for this workload)
SML_DB_MAX_CONNS=3
